{
  "name": "ethoslife-platform",
  "version": "2.0.0",
  "description": "EthosLife Health Operating System - Full-stack health platform with AI, Web3, and marketplace",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node -e \"require('./database').initDatabase().then(() => process.exit(0))\"",
    "db:migrate": "node scripts/migrate.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "health",
    "wellness",
    "ai",
    "web3",
    "fitness",
    "nutrition",
    "marketplace"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "node-telegram-bot-api": "^0.64.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "fs-extra": "^11.2.0",
    "jsonwebtoken": "^9.0.2",
    "google-auth-library": "^9.0.0",
    "bcrypt": "^5.1.1",
    "nodemailer": "^6.9.7",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
