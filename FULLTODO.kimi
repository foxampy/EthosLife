## 📋 PHASE 1: HEALTH MODULES CORE (4-6 недель)

### PHASE 1.1: NUTRITION DEEP DIVE (Неделя 1-2)

#### Database Schema Extensions
```sql
-- Core Tables
nutrition_foods
├── id (uuid) PRIMARY KEY
├── name (varchar 255)
├── brand (varchar 100, nullable)
├── barcode (varchar 50, indexed) -- For scanner
├── category (enum: grains, proteins, dairy, vegetables, fruits, fats, beverages, snacks, supplements, other)
├── serving_size (decimal 10,2) -- grams
├── serving_unit (varchar 20)
├── is_verified (boolean) -- USDA verified
├── is_user_created (boolean)
├── created_by_user_id (uuid, nullable)
├── source (enum: 'usda', 'openfoodfacts', 'custom', 'recipe')
└── nutrients (JSONB)
    ├── calories (kcal)
    ├── protein, carbs, fat (g)
    ├── fiber, sugar (g)
    ├── sodium, cholesterol (mg)
    ├── vitamins (A, C, D, E, K, B-complex)
    └── minerals (calcium, iron, magnesium, etc.)

nutrition_recipes
├── id (uuid)
├── user_id (uuid)
├── name (varchar 255)
├── description (text)
├── instructions (text[])
├── prep_time_minutes (int)
├── cook_time_minutes (int)
├── servings (int)
├── difficulty (enum: easy, medium, hard)
├── tags (varchar[])
├── image_url (varchar)
├── is_public (boolean)
├── likes_count (int)
└── total_nutrients (JSONB)

nutrition_recipe_ingredients
├── id (uuid)
├── recipe_id (uuid)
├── food_id (uuid)
├── amount (decimal 10,2)
├── unit (varchar 20)
└── notes (text)

nutrition_diary_entries
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── meal_type (enum: breakfast, lunch, dinner, snack, pre_workout, post_workout)
├── entry_type (enum: food, recipe, quick_add, barcode)
├── food_id (uuid, nullable)
├── recipe_id (uuid, nullable)
├── custom_name (varchar 255, nullable)
├── amount (decimal 10,2)
├── unit (varchar 20)
├── calculated_nutrients (JSONB)
├── photo_url (varchar, nullable)
├── logged_at (timestamp)
├── location (JSONB, nullable) -- GPS
├── mood (enum: hungry, satisfied, full, stuffed)
├── hunger_level_before (int 1-10)
├── hunger_level_after (int 1-10)
├── ai_analysis (JSONB)
└── notes (text)

nutrition_goals
├── id (uuid)
├── user_id (uuid)
├── goal_type (enum: lose_weight, maintain, gain_weight, gain_muscle, improve_health)
├── target_calories (int)
├── macro_goals (JSONB) -- protein%, carbs%, fat%
├── macro_grams (JSONB) -- exact grams
├── target_water_ml (int)
├── fasting_schedule (JSONB) -- 16:8, 18:6, etc.
├── dietary_restrictions (varchar[]) -- vegetarian, vegan, keto, etc.
├── allergies (varchar[])
├── avoid_foods (varchar[])
├── prefer_foods (varchar[])
├── meal_frequency (int) -- 3-6 meals
└── is_active (boolean)

nutrition_water_log
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── amount_ml (int)
├── logged_at (timestamp)
└── source (enum: manual, reminder)

nutrition_weight_log
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── weight_kg (decimal 5,2)
├── body_fat_percent (decimal 4,1, nullable)
├── muscle_mass_kg (decimal 5,2, nullable)
├── waist_cm (decimal 5,2, nullable)
└── photo_url (varchar, nullable)

nutrition_ai_insights
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── insight_type (enum: pattern, warning, recommendation, achievement)
├── title (varchar 255)
├── description (text)
├── priority (enum: low, medium, high)
├── is_read (boolean)
└── actionable_steps (JSONB[])
```

#### API Endpoints
```typescript
// Foods
GET    /api/nutrition/foods/search?q={query}&limit=20
GET    /api/nutrition/foods/barcode/{barcode}
POST   /api/nutrition/foods (create custom food)
GET    /api/nutrition/foods/:id

// Recipes
GET    /api/nutrition/recipes?public=true&page=1
POST   /api/nutrition/recipes (create recipe)
GET    /api/nutrition/recipes/:id
PUT    /api/nutrition/recipes/:id
DELETE /api/nutrition/recipes/:id
POST   /api/nutrition/recipes/:id/like

// Diary
GET    /api/nutrition/diary?date=2026-03-06
POST   /api/nutrition/diary/entries (add entry)
PUT    /api/nutrition/diary/entries/:id
DELETE /api/nutrition/diary/entries/:id
GET    /api/nutrition/diary/summary?startDate=&endDate=

// Goals
GET    /api/nutrition/goals
POST   /api/nutrition/goals
PUT    /api/nutrition/goals/:id

// Water
GET    /api/nutrition/water?date=2026-03-06
POST   /api/nutrition/water (log water)
DELETE /api/nutrition/water/:id

// Weight
GET    /api/nutrition/weight/history?days=30
POST   /api/nutrition/weight

// Insights
GET    /api/nutrition/insights
POST   /api/nutrition/insights/:id/read
```

#### Frontend Components
```typescript
// Pages
NutritionDashboard.tsx        // Main dashboard
├── CircularProgress          // Calories circle
├── MacroBars                 // Protein/Carbs/Fat progress
├── MealTimeline              // Today's meals
├── WaterTracker              // Animated water counter
├── QuickAddModal             // Fast food entry
├── AISuggestionCard          // AI recommendations

FoodSearch.tsx                // Search with barcode
├── BarcodeScanner            // Camera scanner
├── SearchResults             // List with filters
├── FoodDetailCard            // Nutrients breakdown

RecipeBuilder.tsx             // Create recipes
├── IngredientSelector        // Add ingredients
├── NutritionCalculator       // Auto-calculate macros
├── InstructionEditor         // Step-by-step

MealPlanner.tsx               // AI meal plans
├── PlanGenerator             // AI generation
├── WeeklyView                // 7-day calendar
├── ShoppingList              // Auto-generated list

// Shared Components
FoodCard.tsx
MealTypeIcon.tsx
NutrientBadge.tsx
CalorieChart.tsx
WeightChart.tsx
```

#### External Integrations
```typescript
// Open Food Facts API
interface OpenFoodFactsService {
  searchByBarcode(barcode: string): Promise<FoodData>;
  searchByName(name: string, limit: number): Promise<FoodData[]>;
}

// USDA FoodData Central
interface USDAService {
  searchFoods(query: string): Promise<USDAFood[]>;
  getFoodDetails(fdcId: string): Promise<USDAFoodDetails>;
}

// AI Photo Analysis
interface AIFoodRecognition {
  analyzePhoto(imageBase64: string): Promise<{
    foodName: string;
    confidence: number;
    estimatedWeight: number;
    calories: number;
    macros: Macros;
  }>;
}
```

