### PHASE 1.4: PSYCHOLOGY DEEP DIVE (Неделя 7-8)

#### Database Schema Extensions
```sql
psychology_mood_entries
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── time_of_day (enum: morning, afternoon, evening, night)
├── overall_mood (int 1-10)
├── energy_level (int 1-10)
├── stress_level (int 1-10)
├── anxiety_level (int 1-10)
├── focus_level (int 1-10)
├── emotions (varchar[]) -- ['happy', 'grateful', 'anxious', 'tired']
├── mood_tags (varchar[]) -- work, family, health, finances
├── journal_entry (text)
├── voice_note_url (varchar)
├── trigger_event (text)
└── created_at

psychology_emotion_checkins
├── id (uuid)
├── user_id (uuid)
├── emotion_name (varchar 50) -- Plutchik wheel
├── emotion_intensity (int 1-10)
├── valence (enum: positive, neutral, negative)
├── arousal (int 1-10)
├── body_sensation (varchar 255) -- where felt in body
└── duration_minutes (int)

psychology_assessments
├── id (uuid)
├── user_id (uuid)
├── assessment_type (enum: phq9, gad7, pss, wb5, who5)
├── total_score (int)
├── severity_level (enum: minimal, mild, moderate, severe)
├── answers (JSONB)
├── interpretation (text)
└── taken_at (timestamp)

psychology_phq9_scores
├── id (uuid)
├── user_id (uuid)
├── total_score (int 0-27)
├── severity (varchar 20)
├── suicidal_ideation_flag (boolean) -- question 9
└── requires_follow_up (boolean)

psychology_gad7_scores
├── id (uuid)
├── user_id (uuid)
├── total_score (int 0-21)
└── severity (varchar 20)

psychology_techniques
├── id (uuid)
├── name (varchar 255)
├── name_ru (varchar 255)
├── category (enum: breathing, meditation, cbt, grounding, mindfulness, gratitude)
├── difficulty (enum: beginner, intermediate, advanced)
├── duration_minutes (int)
├── description (text)
├── instructions (text[])
├── audio_url (varchar)
├── video_url (varchar)
├── target_symptoms (varchar[]) -- anxiety, depression, stress
└── is_premium (boolean)

psychology_technique_sessions
├── id (uuid)
├── user_id (uuid)
├── technique_id (uuid)
├── started_at (timestamp)
├── completed_at (timestamp)
├── duration_seconds (int)
├── effectiveness_rating (int 1-10)
├── pre_stress_level (int 1-10)
├── post_stress_level (int 1-10)
└── notes (text)

psychology_journal_entries
├── id (uuid)
├── user_id (uuid)
├── entry_type (enum: free_form, gratitude, worry_dump, cognitive_restructuring)
├── title (varchar 255)
├── content (text)
├── ai_analysis (JSONB)
│   ├── sentiment_score (decimal 3,2) -- -1 to 1
│   ├── key_themes (varchar[])
│   ├── suggested_techniques (uuid[])
│   ├── cognitive_distortions_detected (varchar[])
│   └── ai_summary (text)
└── word_count (int)

psychology_cbt_worksheets
├── id (uuid)
├── user_id (uuid)
├── worksheet_type (enum: thought_record, behavioral_activation, worry_tree)
├── situation (text)
├── automatic_thoughts (text)
├── emotions (varchar[])
├── evidence_for (text)
├── evidence_against (text)
├── balanced_thought (text)
├── action_plan (text)
└── created_at
```

