### PHASE 1.2: MOVEMENT DEEP DIVE (Неделя 3-4)

#### Database Schema Extensions
```sql
movement_daily_activity
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── steps (int)
├── distance_meters (int)
├── calories_burned (int)
├── active_minutes (int)
├── floors_climbed (int)
├── source (enum: manual, phone, wearable)
└── is_goal_achieved (boolean)

movement_workouts
├── id (uuid)
├── user_id (uuid)
├── workout_type (enum: cardio, strength, hiit, yoga, pilates, running, cycling, swimming, walking, sports)
├── name (varchar 255)
├── start_time (timestamp)
├── end_time (timestamp)
├── duration_seconds (int)
├── calories_burned (int)
├── heart_rate_avg (int)
├── heart_rate_max (int)
├── heart_rate_min (int)
├── feeling_rating (int 1-10)
├── rpe (int 6-20) -- Rate of Perceived Exertion
├── location_data (JSONB) -- GPS track
├── is_planned (boolean)
└── notes (text)

movement_workout_exercises
├── id (uuid)
├── workout_id (uuid)
├── exercise_id (uuid)
├── exercise_name (varchar 255) -- denormalized
├── order_index (int)
├── rest_seconds (int)
└── sets (JSONB[]) -- [{reps, weight_kg, duration, distance, rpe, notes}]

movement_exercises (reference table)
├── id (uuid)
├── name (varchar 255)
├── name_ru (varchar 255)
├── category (enum: cardio, strength, flexibility, balance, plyometrics)
├── muscle_groups (varchar[]) -- ['chest', 'back', 'legs', 'shoulders', 'arms', 'core']
├── equipment (varchar[]) -- ['none', 'dumbbells', 'barbell', 'kettlebell', 'machine']
├── difficulty (enum: beginner, intermediate, advanced)
├── instructions (text[])
├── video_url (varchar)
├── image_url (varchar)
├── met_value (decimal 4,2) -- Metabolic Equivalent
└── tags (varchar[])

movement_programs
├── id (uuid)
├── name (varchar 255)
├── goal (enum: lose_weight, build_muscle, improve_endurance, general_fitness)
├── difficulty (enum: beginner, intermediate, advanced)
├── duration_weeks (int)
├── days_per_week (int)
├── equipment_needed (varchar[])
├── is_ai_generated (boolean)
├── weeks (JSONB[]) -- structured program
└── is_public (boolean)

movement_planned_workouts
├── id (uuid)
├── user_id (uuid)
├── program_id (uuid, nullable)
├── name (varchar 255)
├── scheduled_date (date)
├── scheduled_time (time)
├── workout_type (enum)
├── estimated_duration_minutes (int)
├── exercises (JSONB[])
├── is_completed (boolean)
├── reminder_enabled (boolean)
└── reminder_time (time)

movement_fitness_metrics
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── vo2_max (decimal 4,1)
├── resting_heart_rate (int)
├── hrv (decimal 5,2) -- Heart Rate Variability
├── body_composition (JSONB)
└── created_at

movement_personal_records
├── id (uuid)
├── user_id (uuid)
├── exercise_id (uuid)
├── pr_type (enum: weight, reps, distance, time, speed)
├── value (decimal 10,2)
├── unit (varchar 20)
├── achieved_at (timestamp)
├── improvement_percent (decimal 5,2)
└── is_notified (boolean)

movement_recovery_status
├── id (uuid)
├── user_id (uuid)
├── date (date)
├── recovery_score (int 0-100)
├── sleep_quality_impact (int -50 to +50)
├── nutrition_impact (int -50 to +50)
├── stress_impact (int -50 to +50)
├── previous_workout_impact (int -50 to +50)
├── readiness_to_train (enum: low, moderate, high, optimal)
├── recommended_intensity (enum: rest, light, moderate, hard)
├── muscle_groups_fatigue (JSONB) -- {chest: 80, legs: 40}
└── ai_recommendation (text)
```

