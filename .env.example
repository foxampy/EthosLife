# EthosLife Environment Configuration

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/ethoslife

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# STRIPE CONFIGURATION (Monetization)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly_xxx
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_premium_yearly_xxx
STRIPE_PRO_PRICE_ID=price_pro_monthly_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_xxx

# ============================================
# TELEGRAM BOT (SAFT Notifications)
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
FOUNDER_CHAT_ID=your_chat_id_here
ADMIN_CHAT_IDS=admin1_chat_id,admin2_chat_id

# ============================================
# ADMIN CONFIGURATION
# ============================================
ADMIN_KEY=your-admin-key-for-api-access

# ============================================
# CORS & FRONTEND
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://ethoslife.vercel.app
FRONTEND_URL=http://localhost:5173

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# AI/ML API KEYS (Optional)
# ============================================
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# WEB3/CRYPTO (Optional)
# ============================================
ALCHEMY_API_KEY=your-alchemy-api-key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
