# ============================================
# EthosLife SAFT Platform - Environment Config
# ============================================
# NEVER commit this file with real values!
# Copy to .env and fill in your values

# PostgreSQL Database
# For local development, you can use:
# DATABASE_URL=postgresql://user:password@localhost:5432/ethoslife
# For Render: automatically set from managed PostgreSQL
DATABASE_URL=postgresql://localhost:5432/ethoslife

# Telegram Bot Configuration
# Get token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID
# Message @userinfobot to get your ID
FOUNDER_CHAT_ID=your_chat_id_here

# Optional: Additional admin chat IDs (comma separated)
ADMIN_CHAT_IDS=

# Admin access key for viewing submissions
# Generate strong random string: openssl rand -hex 32
ADMIN_KEY=your_secret_admin_key_min_32_chars

# Server Configuration
PORT=3000
NODE_ENV=development

# SSL Mode for PostgreSQL (set to 'no-verify' for Render)
PGSSLMODE=no-verify
